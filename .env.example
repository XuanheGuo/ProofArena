# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
#
# Copy this file to .env.local and fill in real values. .env.local is
# git-ignored — never commit it.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — only for server-side scripts (seed, migrations, verify-*).
# NEVER expose in frontend code or commit a real value here.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: CAS microservice URL. Defaults to http://localhost:8000 in dev.
CAS_SERVICE_URL=

# Unified verification system (server-only except the feature flag value rendered by RSC).
# Keep disabled until migration 024 is applied and AXLE credentials are configured.
LEAN_VERIFICATION_ENABLED=false
LEAN_VERIFICATION_PROVIDER=axle
AXLE_API_KEY=
AXLE_BASE_URL=https://axle.axiommath.ai
# One environment, or a comma-separated server allowlist (first is the default).
AXLE_ENVIRONMENT=
AXLE_TIMEOUT_SECONDS=120
